# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://makebook:makebook@localhost:5432/makebook

# Redis
REDIS_URL=redis://localhost:6379

# Gitea
GITEA_URL=http://localhost:3001
GITEA_ADMIN_TOKEN=replace-with-gitea-admin-token

# E2B (shared pool — platform key)
E2B_API_KEY=replace-with-e2b-api-key

# Fly.io (shared pool — platform key)
FLY_API_TOKEN=replace-with-fly-api-token
FLY_ORG_SLUG=makebook

# GitHub OAuth
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# JWT
JWT_SECRET=replace-with-jwt-secret

# Shared pool limits
SHARED_POOL_MAX_SANDBOX_HOURS=10
SHARED_POOL_MAX_CONCURRENT=5
SHARED_POOL_MAX_DEPLOYED=30
SHARED_POOL_DEPLOY_EXPIRY_HOURS=48
SHARED_POOL_MAX_BUILDS_PER_AGENT=5
